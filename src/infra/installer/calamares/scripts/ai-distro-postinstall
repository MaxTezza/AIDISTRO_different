#!/bin/sh
set -e

# ═══════════════════════════════════════════════════════════════════
# AI Distro — Post-Install Script (Calamares)
#
# Runs inside the newly installed system (chroot) after unpackfs.
# Enables all AI Distro services and sets up first-boot experience.
# ═══════════════════════════════════════════════════════════════════

echo "AI Distro: Running post-install configuration..."

# ── 1. Enable systemd services ──────────────────────────────────
if command -v systemctl >/dev/null 2>&1; then
    for svc in \
        ai-distro-agent \
        ai-distro-voice \
        ai-distro-curator \
        ai-distro-healer \
        ai-distro-spirit \
        ai-distro-hardware \
        ai-distro-vision \
        ai-distro-eventbus \
        ai-distro-wakeword \
        ai-distro-dashboard; do
        systemctl enable "${svc}.service" 2>/dev/null || true
    done
    systemctl enable ai-distro-agent.socket 2>/dev/null || true
    echo "  ✔ Enabled AI Distro services"
fi

# ── 2. Autostart shell ──────────────────────────────────────────
autostart_dir="/etc/xdg/autostart"
mkdir -p "${autostart_dir}"

cat <<'EOF' >"${autostart_dir}/ai-distro-shell.desktop"
[Desktop Entry]
Type=Application
Exec=/usr/bin/python3 /usr/lib/ai-distro/ai_distro_shell.py
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
Name=AI Distro Shell
Comment=Launch the AI Distro assistant shell on login
EOF
chmod 644 "${autostart_dir}/ai-distro-shell.desktop"
echo "  ✔ Configured autostart"

# ── 3. Skeleton configs for new users ───────────────────────────
skel_dir="/etc/skel/.config/ai-distro"
mkdir -p "${skel_dir}"

cat <<'EOF' >"${skel_dir}/plugins.json"
{}
EOF

cat <<'EOF' >"${skel_dir}/lite-mode.json"
{"enabled": false}
EOF

cat <<'EOF' >"${skel_dir}/providers.json"
{"calendar": "local", "email": "gmail", "weather": "default"}
EOF

# Default locale
cat <<'EOF' >"${skel_dir}/../ai-distro-locale.json"
{"locale": "en"}
EOF
echo "  ✔ Populated skeleton configs"

# ── 4. First-boot setup wizard trigger ──────────────────────────
cat <<'EOF' >"${autostart_dir}/ai-distro-setup.desktop"
[Desktop Entry]
Type=Application
Exec=/usr/bin/python3 /usr/lib/ai-distro/tools/agent/setup_wizard.py --first-boot
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
Name=AI Distro Setup
Comment=First-boot setup wizard
EOF
chmod 644 "${autostart_dir}/ai-distro-setup.desktop"
echo "  ✔ Configured first-boot setup wizard"

# ── 5. Dashboard bookmark ──────────────────────────────────────
# Create a .desktop shortcut for the web dashboard
apps_dir="/usr/share/applications"
mkdir -p "${apps_dir}"
cat <<'EOF' >"${apps_dir}/ai-distro-dashboard.desktop"
[Desktop Entry]
Type=Application
Name=AI Distro Dashboard
Comment=System monitoring and control center
Exec=xdg-open http://localhost:7841
Icon=utilities-system-monitor
Categories=System;Monitor;
EOF
echo "  ✔ Created dashboard shortcut"

# ── 6. Ensure proper permissions ────────────────────────────────
mkdir -p /run/ai-distro
chmod 755 /run/ai-distro

echo "AI Distro: Post-install complete."
exit 0
