{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mnemonicos",
  "version": "0.1.0",
  "identifier": "com.mnemonicos.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 4173 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mnemonic OS",
        "width": 1280,
        "height": 800,
        "fullscreen": false,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
