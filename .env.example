# AI Distro Environment Configuration
# Copy this file to .env and adjust values for your system.

# --- IPC Sockets ---
AI_DISTRO_IPC_SOCKET=/tmp/ai-distro-agent.sock
AI_DISTRO_CORE_SOCKET=/tmp/ai-distro-core.sock

# --- Data Directories ---
AI_DISTRO_MEMORY_DIR=/var/lib/ai-distro/memory
AI_DISTRO_CONFIRM_DIR=/var/lib/ai-distro/confirmations
AI_DISTRO_SKILLS_DIR=./src/skills/core

# --- State / Context ---
AI_DISTRO_CORE_STATE_DB=/var/lib/ai-distro/state.db
AI_DISTRO_CORE_CONTEXT_DIR=/var/lib/ai-distro/context

# --- Python Tool Paths ---
AI_DISTRO_INTENT_PARSER=./tools/agent/intent_parser.py
AI_DISTRO_BRAIN=./tools/agent/brain.py

# --- Cloud LLM Fallback (optional) ---
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# --- Spirit Bridge / Telegram Bot (optional) ---
# AI_DISTRO_TELEGRAM_TOKEN=your-bot-token

# --- Model Paths (defaults to ~/.cache/ai-distro/models/) ---
# AI_DISTRO_MODEL_PATH=~/.cache/ai-distro/models/llama-3.2-1b-instruct.gguf
